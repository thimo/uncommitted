.DS_Store
.build/
.swiftpm/
build/

# VSCode: ignore everything by default, allow-list the files that are
# actually shared project configuration.
.vscode/*
!.vscode/launch.json
!.vscode/extensions.json

# Signing credentials for release.sh (local only, never committed).
.env.local

# Per-device editor/tooling overrides (never committed).
.claude/settings.local.json

# Peekaboo screenshots dumped during dev sessions.
screen0_*.png
